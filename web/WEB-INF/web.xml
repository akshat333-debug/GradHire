<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
         http://xmlns.jcp.org/xml/ns/javaee/web-app_6_0.xsd"
         version="4.0">
    
    <!-- Application Display Name -->
    <display-name>GradHire - Job Portal for College Students</display-name>
    
    <!-- Application Description -->
    <description>
        GradHire is a job portal connecting college students with internships 
        and entry-level positions based on their skills and domains.
    </description>
    
    <!-- ========================================= -->
    <!-- WELCOME FILE LIST -->
    <!-- ========================================= -->
    <welcome-file-list>
        <welcome-file>index.html</welcome-file>
        <welcome-file>index.jsp</welcome-file>
        <welcome-file>login</welcome-file>
    </welcome-file-list>
    
    <!-- ========================================= -->
    <!-- SESSION CONFIGURATION -->
    <!-- ========================================= -->
    <session-config>
        <!-- Session timeout in minutes -->
        <session-timeout>30</session-timeout>
        <cookie-config>
            <http-only>true</http-only>
            <!-- <secure>true</secure> --> <!-- Uncomment for HTTPS -->
        </cookie-config>
    </session-config>
    
    <!-- ========================================= -->
    <!-- CONTEXT PARAMETERS -->
    <!-- ========================================= -->
    <context-param>
        <param-name>app.name</param-name>
        <param-value>GradHire</param-value>
    </context-param>
    
    <context-param>
        <param-name>app.version</param-name>
        <param-value>1.0</param-value>
    </context-param>
    
    <!-- JSP Configuration -->
    <jsp-config>
        <jsp-property-group>
            <url-pattern>*.jsp</url-pattern>
            <page-encoding>UTF-8</page-encoding>
            <scripting-invalid>false</scripting-invalid>
            <include-prelude>/WEB-INF/jsp/common/taglibs.jsp</include-prelude>
        </jsp-property-group>
    </jsp-config>
    
    <!-- ========================================= -->
    <!-- FILTERS - Authentication & Authorization -->
    <!-- ========================================= -->
    <!-- Note: Filters are also configured with @WebFilter annotations -->
    <!-- This configuration ensures proper ordering -->
    
    <!-- Authentication Filter - checks if user is logged in -->
    <filter>
        <filter-name>AuthenticationFilter</filter-name>
        <filter-class>com.gradhire.filter.AuthenticationFilter</filter-class>
    </filter>
    
    <filter-mapping>
        <filter-name>AuthenticationFilter</filter-name>
        <url-pattern>/student/*</url-pattern>
        <url-pattern>/admin/*</url-pattern>
    </filter-mapping>
    
    <!-- Authorization Filter - checks user role/permissions -->
    <filter>
        <filter-name>AuthorizationFilter</filter-name>
        <filter-class>com.gradhire.filter.AuthorizationFilter</filter-class>
    </filter>
    
    <filter-mapping>
        <filter-name>AuthorizationFilter</filter-name>
        <url-pattern>/student/*</url-pattern>
        <url-pattern>/admin/*</url-pattern>
    </filter-mapping>
    
    <!-- ========================================= -->
    <!-- SERVLETS -->
    <!-- ========================================= -->
    
    <!-- Login Servlet -->
    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>com.gradhire.servlet.LoginServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>
    
    <!-- Register Servlet -->
    <servlet>
        <servlet-name>RegisterServlet</servlet-name>
        <servlet-class>com.gradhire.servlet.RegisterServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>RegisterServlet</servlet-name>
        <url-pattern>/register</url-pattern>
    </servlet-mapping>
    
    <!-- Logout Servlet -->
    <servlet>
        <servlet-name>LogoutServlet</servlet-name>
        <servlet-class>com.gradhire.servlet.LogoutServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LogoutServlet</servlet-name>
        <url-pattern>/logout</url-pattern>
    </servlet-mapping>
    
    <!-- Job Listing Servlet -->
    <servlet>
        <servlet-name>JobListingServlet</servlet-name>
        <servlet-class>com.gradhire.servlet.JobListingServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>JobListingServlet</servlet-name>
        <url-pattern>/jobs</url-pattern>
    </servlet-mapping>
    
    <!-- Job Detail Servlet -->
    <servlet>
        <servlet-name>JobDetailServlet</servlet-name>
        <servlet-class>com.gradhire.servlet.JobDetailServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>JobDetailServlet</servlet-name>
        <url-pattern>/job/*</url-pattern>
    </servlet-mapping>
    
    <!-- Apply Servlet -->
    <servlet>
        <servlet-name>ApplyServlet</servlet-name>
        <servlet-class>com.gradhire.servlet.ApplyServlet</servlet-class>
        <multipart-config>
            <max-file-size>10485760</max-file-size> <!-- 10MB -->
            <max-request-size>20971520</max-request-size> <!-- 20MB -->
            <file-size-threshold>1048576</file-size-threshold> <!-- 1MB -->
        </multipart-config>
    </servlet>
    <servlet-mapping>
        <servlet-name>ApplyServlet</servlet-name>
        <url-pattern>/apply</url-pattern>
    </servlet-mapping>
    
    <!-- Student Dashboard Servlet -->
    <servlet>
        <servlet-name>StudentDashboardServlet</servlet-name>
        <servlet-class>com.gradhire.servlet.StudentDashboardServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>StudentDashboardServlet</servlet-name>
        <url-pattern>/student/dashboard</url-pattern>
    </servlet-mapping>
    
    <!-- Admin Dashboard Servlet -->
    <servlet>
        <servlet-name>AdminDashboardServlet</servlet-name>
        <servlet-class>com.gradhire.servlet.AdminDashboardServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminDashboardServlet</servlet-name>
        <url-pattern>/admin/dashboard</url-pattern>
    </servlet-mapping>
    
    <!-- Admin Analytics Servlet -->
    <servlet>
        <servlet-name>AdminAnalyticsServlet</servlet-name>
        <servlet-class>com.gradhire.servlet.AdminAnalyticsServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminAnalyticsServlet</servlet-name>
        <url-pattern>/admin/analytics</url-pattern>
    </servlet-mapping>
    
    <!-- Profile Servlet -->
    <servlet>
        <servlet-name>ProfileServlet</servlet-name>
        <servlet-class>com.gradhire.servlet.ProfileServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ProfileServlet</servlet-name>
        <url-pattern>/student/profile</url-pattern>
    </servlet-mapping>
    
    <!-- Student Recommendations Servlet -->
    <servlet>
        <servlet-name>StudentRecommendationsServlet</servlet-name>
        <servlet-class>com.gradhire.servlet.StudentRecommendationsServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>StudentRecommendationsServlet</servlet-name>
        <url-pattern>/student/recommendations</url-pattern>
    </servlet-mapping>
    
    <!-- Student Applications Servlet -->
    <servlet>
        <servlet-name>StudentApplicationsServlet</servlet-name>
        <servlet-class>com.gradhire.servlet.StudentApplicationsServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>StudentApplicationsServlet</servlet-name>
        <url-pattern>/student/applications</url-pattern>
    </servlet-mapping>

    <!-- Student Settings Servlet -->
    <servlet>
        <servlet-name>StudentSettingsServlet</servlet-name>
        <servlet-class>com.gradhire.servlet.StudentSettingsServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>StudentSettingsServlet</servlet-name>
        <url-pattern>/student/settings</url-pattern>
    </servlet-mapping>
    
    <!-- Admin Applications Servlet -->
    <servlet>
        <servlet-name>AdminApplicationsServlet</servlet-name>
        <servlet-class>com.gradhire.servlet.AdminApplicationsServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminApplicationsServlet</servlet-name>
        <url-pattern>/admin/applications</url-pattern>
    </servlet-mapping>
    
    <!-- Admin Candidates Servlet -->
    <servlet>
        <servlet-name>AdminCandidatesServlet</servlet-name>
        <servlet-class>com.gradhire.servlet.AdminCandidatesServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminCandidatesServlet</servlet-name>
        <url-pattern>/admin/candidates</url-pattern>
    </servlet-mapping>
    
    <!-- Admin Jobs Servlet -->
    <servlet>
        <servlet-name>AdminJobsServlet</servlet-name>
        <servlet-class>com.gradhire.servlet.AdminJobsServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminJobsServlet</servlet-name>
        <url-pattern>/admin/jobs</url-pattern>
    </servlet-mapping>
    
    <!-- Job Post Servlet -->
    <servlet>
        <servlet-name>JobPostServlet</servlet-name>
        <servlet-class>com.gradhire.servlet.JobPostServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>JobPostServlet</servlet-name>
        <url-pattern>/admin/jobs/post</url-pattern>
    </servlet-mapping>

    <!-- Job Draft Servlet -->
    <servlet>
        <servlet-name>AdminJobDraftServlet</servlet-name>
        <servlet-class>com.gradhire.servlet.AdminJobDraftServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminJobDraftServlet</servlet-name>
        <url-pattern>/admin/jobs/save-draft</url-pattern>
    </servlet-mapping>
    
    <!-- ========================================= -->
    <!-- ERROR PAGES -->
    <!-- ========================================= -->
    <error-page>
        <error-code>404</error-code>
        <location>/WEB-INF/jsp/error/404.jsp</location>
    </error-page>
    
    <error-page>
        <error-code>403</error-code>
        <location>/WEB-INF/jsp/error/403.jsp</location>
    </error-page>
    
    <error-page>
        <error-code>500</error-code>
        <location>/WEB-INF/jsp/error/500.jsp</location>
    </error-page>
    
    <error-page>
        <exception-type>java.lang.Exception</exception-type>
        <location>/WEB-INF/jsp/error/error.jsp</location>
    </error-page>
    
    <!-- ========================================= -->
    <!-- MIME TYPE MAPPINGS -->
    <!-- ========================================= -->
    <mime-mapping>
        <extension>pdf</extension>
        <mime-type>application/pdf</mime-type>
    </mime-mapping>
    
    <mime-mapping>
        <extension>doc</extension>
        <mime-type>application/msword</mime-type>
    </mime-mapping>
    
    <mime-mapping>
        <extension>docx</extension>
        <mime-type>application/vnd.openxmlformats-officedocument.wordprocessingml.document</mime-type>
    </mime-mapping>
    
    <!-- ========================================= -->
    <!-- SECURITY CONSTRAINTS (Optional) -->
    <!-- ========================================= -->
    <!-- Uncomment to enable HTTPS -->
    <!--
    <security-constraint>
        <web-resource-collection>
            <web-resource-name>Secure Area</web-resource-name>
            <url-pattern>/*</url-pattern>
        </web-resource-collection>
        <user-data-constraint>
            <transport-guarantee>CONFIDENTIAL</transport-guarantee>
        </user-data-constraint>
    </security-constraint>
    -->
    
</web-app>

